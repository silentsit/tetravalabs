DATABASE_URL=postgres://postgres:postgres@localhost:5432/tetrava_medusa
USE_REDIS=false
# Local: redis://localhost:6379
# Upstash (Render production): use the "Redis URL" from the Upstash dashboard — NOT the REST URL.
# Must start with rediss:// (TLS), e.g. rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
COOKIE_SECRET=change-me
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000

# Catalog import (optional; import script can login with email/password)
MEDUSA_ADMIN_URL=http://localhost:9000
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me
# MEDUSA_ADMIN_TOKEN=
# MEDUSA_SALES_CHANNEL_ID=

# Payments
# Optional debug override — leave unset for dual routing (BTC→BTCPay, others→Paymento)
# CRYPTO_PROVIDER=btcpay
CRYPTO_WEBHOOK_SECRET=replace-me
CRYPTO_API_URL=
CRYPTO_CHECKOUT_BASE_URL=
BTCPAY_URL=
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=
PAYMENTO_API_KEY=
PAYMENTO_SECRET_KEY=
PAYMENTO_SPEED=1
STOREFRONT_URL=http://localhost:3000

# COA storage
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Email
RESEND_API_KEY=

# Typesense
TYPESENSE_PROTOCOL=http
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION=products
