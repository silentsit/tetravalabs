DATABASE_URL=postgres://postgres:postgres@localhost:5432/tetrava_medusa
# Neon production: use the **pooled** connection string (host contains -pooler).
# Use sslmode=require only — omit channel_binding=require (breaks many clients).
USE_REDIS=false
# Local: redis://localhost:6379
# Upstash (Render production): use the "Redis URL" from the Upstash dashboard — NOT the REST URL.
# Must start with rediss:// (TLS), e.g. rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
COOKIE_SECRET=change-me
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000
# Render production: set ENABLE_MEDUSA_ADMIN=true (admin disabled when NODE_ENV=production)
# ENABLE_MEDUSA_ADMIN=true

# Catalog import (optional; import script can login with email/password)
MEDUSA_ADMIN_URL=http://localhost:9000
MEDUSA_ADMIN_EMAIL=info@tetravalabs.com
MEDUSA_ADMIN_PASSWORD=change-me
LEGACY_ADMIN_EMAIL=admin@tetravalabs.com
# Optional override for storefront review moderation (comma-separated). Defaults to admin emails above.
# STORE_ADMIN_EMAILS=info@tetravalabs.com,admin@tetravalabs.com
# MEDUSA_ADMIN_TOKEN=
# MEDUSA_SALES_CHANNEL_ID=

# Payments
# Optional debug override — leave unset for dual routing (BTC→BTCPay, others→Paymento)
# CRYPTO_PROVIDER=btcpay
CRYPTO_WEBHOOK_SECRET=replace-me
CRYPTO_API_URL=
CRYPTO_CHECKOUT_BASE_URL=
BTCPAY_URL=
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=
PAYMENTO_API_KEY=
PAYMENTO_SECRET_KEY=
PAYMENTO_SPEED=1
PEPTIDEPAY_API_KEY=
PEPTIDEPAY_WEBHOOK_SECRET=
# Public Medusa URL for Peptide Pay webhooks (Render production URL)
MEDUSA_PUBLIC_URL=http://localhost:9000
STOREFRONT_URL=http://localhost:3000

# Transactional email (paid order confirmation, password reset, unpaid payment reminders)
RESEND_API_KEY=
RESEND_FROM=Tetrava Labs <orders@tetravalabs.com>
# Optional promo codes shown in select lifecycle emails (create matching codes in Medusa Admin)
# EMAIL_PROMO_CHECKOUT_ABANDON=
# EMAIL_PROMO_WINBACK=
# EMAIL_PROMO_REPLENISHMENT=
# Secures POST /hooks/order-emails/process and POST /hooks/orders/ship
# (Render cron + ops shipping; header: x-order-email-cron-secret)
ORDER_EMAIL_CRON_SECRET=

# Google OAuth (storefront customer sign-in)
# MEDUSA_AUTH_GOOGLE_CLIENT_ID=
# MEDUSA_AUTH_GOOGLE_CLIENT_SECRET=

# Apple Sign In (Services ID + .p8 key)
# MEDUSA_AUTH_APPLE_CLIENT_ID=
# MEDUSA_AUTH_APPLE_TEAM_ID=
# MEDUSA_AUTH_APPLE_KEY_ID=
# MEDUSA_AUTH_APPLE_PRIVATE_KEY=

# COA storage (Cloudflare R2)
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Typesense Cloud (recommended) or local Docker (docker-compose.local.yml)
TYPESENSE_PROTOCOL=https
# Hostname only — no https:// prefix (e.g. ep2o587yr1z9dcwkp-1.a1.typesense.net)
TYPESENSE_HOST=
TYPESENSE_PORT=443
TYPESENSE_API_KEY=
TYPESENSE_COLLECTION=products
# Enables POST /hooks/typesense/sync (set same value in x-typesense-sync-secret header)
TYPESENSE_SYNC_SECRET=
# Used by preDeploy typesense:index on Render
MEDUSA_PUBLISHABLE_KEY=
