{
  "name": "@tetrava/medusa",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "medusa develop",
    "start": "medusa start",
    "build:backend": "tsc -p tsconfig.json --noEmit",
    "build": "medusa build || npm run build:backend",
    "seed": "node ./src/scripts/seed-catalog.mjs",
    "db:migrate": "medusa db:migrate",
    "db:lab-schema": "node ./src/scripts/apply-lab-schema.mjs",
    "bootstrap:admin": "medusa exec ./src/scripts/bootstrap-admin.ts",
    "coa:import-sample": "node ./src/scripts/import-coa-docs.mjs"
  },
  "dependencies": {
    "@medusajs/framework": "^2.11.2",
    "@medusajs/medusa": "^2.11.2",
    "@medusajs/payment": "^2.11.2",
    "dotenv": "^16.5.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
