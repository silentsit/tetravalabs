{
  "name": "@tetrava/medusa",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "medusa develop",
    "start": "node ./scripts/start.mjs",
    "build": "medusa build && node ./scripts/copy-database-url.mjs",
    "build:backend": "npm run build",
    "build:admin": "medusa build",
    "seed": "node ./src/scripts/seed-catalog.mjs",
    "db:migrate": "node ./scripts/prepare-db-env.mjs && medusa db:migrate",
    "db:lab-schema": "node ./src/scripts/apply-lab-schema.mjs",
    "bootstrap:admin": "medusa exec ./src/scripts/bootstrap-admin.mjs",
    "bootstrap:customer": "medusa exec ./src/scripts/bootstrap-customer.mjs",
    "remove:legacy-admin": "medusa exec ./src/scripts/remove-legacy-admin.mjs",
    "bootstrap:store": "node ./src/scripts/bootstrap-store.mjs",
    "bootstrap:store:rotate": "node ./src/scripts/bootstrap-store.mjs --rotate-key",
    "coa:import-sample": "node ./src/scripts/import-coa-docs.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@medusajs/auth-google": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/link-modules": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/payment": "2.15.5",
    "@medusajs/ui": "^4.1.15",
    "@medusajs/ui-preset": "^2.15.5",
    "dotenv": "^16.5.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
