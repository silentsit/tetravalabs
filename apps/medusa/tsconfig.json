{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": ".medusa/server",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "medusa-config.ts",
    "src/**/*.ts",
    "src/**/*.mts"
  ],
  "exclude": [
    "node_modules",
    ".medusa/server",
    ".medusa/admin",
    "src/admin"
  ]
}
