NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Use production Render URL when local Medusa is not running (npm run medusa:dev).
NEXT_PUBLIC_MEDUSA_URL=https://tetrava-medusa.onrender.com
# For fully local stack: NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
REVALIDATE_SECRET=
RESTRICTED_COUNTRIES=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional: Coinbase Onramp app ID for branded US deep links (Tab B)
NEXT_PUBLIC_COINBASE_APP_ID=

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
# Editor token for npm run sanity:seed (local only — do not expose to browser)
SANITY_API_WRITE_TOKEN=

TYPESENSE_PROTOCOL=http
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION=products
# Production search uses Medusa /store/search (Typesense on Render private network).
# Vercel does not need Typesense env vars.

RESEND_API_KEY=
RESEND_FROM=Tetrava Labs <orders@tetravalabs.com>
CONTACT_TO_EMAIL=info@tetravalabs.com
