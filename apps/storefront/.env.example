NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Use production Render URL when local Medusa is not running (npm run medusa:dev).
NEXT_PUBLIC_MEDUSA_URL=https://tetrava-medusa-i44n.onrender.com
# For fully local stack: NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
REVALIDATE_SECRET=
RESTRICTED_COUNTRIES=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional: Coinbase Onramp app ID for branded US deep links (Tab B)
NEXT_PUBLIC_COINBASE_APP_ID=

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
# Editor token for npm run sanity:seed (local only — do not expose to browser)
SANITY_API_WRITE_TOKEN=

# Typesense Cloud — for local `npm run typesense:index` only
TYPESENSE_PROTOCOL=https
TYPESENSE_HOST=
TYPESENSE_PORT=443
TYPESENSE_API_KEY=
TYPESENSE_COLLECTION=products
# Live search uses Medusa GET /store/search (Typesense env on Render Medusa).

# Comma-separated storefront admin emails allowed to post custom-name reviews and delete reviews.
NEXT_PUBLIC_STORE_ADMIN_EMAILS=info@tetravalabs.com,admin@tetravalabs.com

# Social sign-in (set false to hide buttons until OAuth is configured)
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
# NEXT_PUBLIC_AUTH_APPLE_ENABLED=false

RESEND_API_KEY=
RESEND_FROM=Tetrava Labs <orders@tetravalabs.com>
CONTACT_TO_EMAIL=info@tetravalabs.com
