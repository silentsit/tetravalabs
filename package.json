{
  "name": "tetravalabs-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/storefront run dev",
    "build": "npm --prefix apps/storefront run build",
    "build:vercel-root": "npm run build --workspace=@tetrava/storefront && node scripts/sync-next-output.mjs",
    "start": "npm --prefix apps/storefront run start",
    "dev:legacy": "npm --prefix app run dev",
    "build:legacy": "npm --prefix app run build",
    "medusa:dev": "npm --prefix apps/medusa run dev",
    "medusa:start": "npm --prefix apps/medusa run start",
    "medusa:bootstrap": "npm --prefix apps/medusa run bootstrap:store",
    "catalog:normalize": "npm --prefix packages/catalog run normalize",
    "catalog:import": "npm --prefix packages/catalog run import:medusa",
    "typesense:index": "npm --prefix packages/catalog run typesense:index",
    "typesense:setup": "node scripts/typesense-setup.mjs",
    "coa:sync-r2": "npm --prefix packages/catalog run coa:sync-r2",
    "smoke:search": "node scripts/smoke-search-production.mjs",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "smoke:checkout": "node scripts/smoke-checkout-production.mjs",
    "btcpay:setup": "node scripts/btcpay-setup.mjs",
    "paymento:setup": "node scripts/paymento-setup.mjs",
    "env:validate": "node scripts/validate-env.mjs",
    "deploy:env": "node scripts/print-deploy-env.mjs",
    "production:checklist": "node scripts/production-checklist.mjs",
    "production:verify": "node scripts/verify-production-alignment.mjs",
    "production:setup": "node scripts/production-data-setup.mjs",
    "production:setup:run": "node scripts/production-data-setup.mjs --run",
    "bootstrap:remote": "node scripts/remote-bootstrap.mjs"
  },
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "next": "^15.5.19",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@medusajs/medusa": "2.15.5"
  }
}
