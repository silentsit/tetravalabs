{
  "name": "tetravalabs-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/storefront run dev",
    "build": "npm --prefix apps/storefront run build",
    "start": "npm --prefix apps/storefront run start",
    "dev:legacy": "npm --prefix app run dev",
    "build:legacy": "npm --prefix app run build",
    "medusa:dev": "npm --prefix apps/medusa run dev",
    "medusa:start": "npm --prefix apps/medusa run start",
    "catalog:normalize": "npm --prefix packages/catalog run normalize",
    "catalog:import": "npm --prefix packages/catalog run import:medusa",
    "typesense:index": "npm --prefix packages/catalog run typesense:index",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "env:validate": "node scripts/validate-env.mjs",
    "deploy:env": "node scripts/print-deploy-env.mjs"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "next": "^15.5.19",
    "ts-node": "^10.9.2"
  }
}
